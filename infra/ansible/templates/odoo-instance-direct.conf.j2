[options]
; ── Security ──────────────────────────────────────────────────────────────────
admin_passwd  = {{ admin_passwd }}

; ── Database ──────────────────────────────────────────────────────────────────
db_host       = False
db_port       = False
db_user       = {{ odoo_user }}
db_password   = False
db_name       = {{ db_name }}
; Lock this process to its own database only
db_filter     = ^{{ db_name }}$

; ── Network ───────────────────────────────────────────────────────────────────
http_port     = {{ http_port }}
proxy_mode    = {{ 'True' if proxy_mode | default(false) else 'False' }}

; ── Isolated environment ──────────────────────────────────────────────────────
; Own filestore, sessions, and attachments directory
data_dir      = {{ data_dir }}

; Own copy of core addons + own custom addons — fully isolated from other instances
addons_path   = {{ core_addons_dir }},{{ custom_addons_dir }}

; ── Logging ───────────────────────────────────────────────────────────────────
logfile       = {{ log_dir }}/{{ db_name }}.log
log_level     = info

; ── Workers ───────────────────────────────────────────────────────────────────
workers           = 2
max_cron_threads  = 1
