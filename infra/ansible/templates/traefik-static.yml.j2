global:
  checkNewVersion: false
  sendAnonymousUsage: false

api:
  dashboard: false

entryPoints:
  web:
    address: ":80"
{% if traefik_tls_mode != 'DISABLED' %}
  websecure:
    address: ":443"
{% endif %}

providers:
  file:
    directory: {{ traefik_dynamic_dir }}
    watch: true

{% if traefik_tls_mode != 'DISABLED' %}
certificatesResolvers:
  letsencrypt:
    acme:
      email: {{ traefik_acme_email }}
      storage: {{ traefik_acme_storage }}
      dnsChallenge:
        provider: cloudflare
        delayBeforeCheck: "10s"
        resolvers:
          - "1.1.1.1:53"
          - "8.8.8.8:53"
{% endif %}

log:
  level: {{ traefik_log_level }}

accessLog: {}
