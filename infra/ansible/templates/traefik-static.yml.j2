global:
  checkNewVersion: false
  sendAnonymousUsage: false

api:
  dashboard: false

entryPoints:
  web:
    address: ":80"
{% if traefik_tls_mode != 'DISABLED' %}
  websecure:
    address: ":443"
{% endif %}

providers:
  file:
    directory: {{ traefik_dynamic_dir }}
    watch: true

{% if traefik_tls_mode != 'DISABLED' %}
certificatesResolvers:
  letsencrypt:
    acme:
      email: {{ traefik_acme_email }}
      storage: {{ traefik_acme_storage }}
{% if traefik_cf_api_token is defined and traefik_cf_api_token %}
      dnsChallenge:
        provider: cloudflare
        resolvers:
          - "1.1.1.1:53"
          - "8.8.8.8:53"
{% else %}
      httpChallenge:
        entryPoint: web
{% endif %}
{% endif %}

log:
  level: {{ traefik_log_level }}

accessLog: {}
