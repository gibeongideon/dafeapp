[Unit]
Description=Odoo Instance {{ db_name }} (v{{ odoo_version }})
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
User={{ odoo_user }}
Group={{ odoo_user }}
WorkingDirectory={{ odoo_home }}/odoo-server
ExecStart=/usr/bin/python3 {{ odoo_bin }} -c {{ config_file }}
Restart=always
RestartSec=5
KillMode=mixed
TimeoutStartSec=180

[Install]
WantedBy=multi-user.target
