[options]
; Auto-generated by DafeApp — do not edit by hand.
; Instance: {{ client_name }}

addons_path = {% if enterprise_addons_host_path is defined and enterprise_addons_host_path %}/mnt/extra-addons,{% endif %}/usr/lib/python3/dist-packages/odoo/addons
data_dir = /var/lib/odoo

db_host = postgres
db_port = 5432
db_user = odoo
db_password = {{ postgres_password }}
db_name = {{ db_name }}

; Restrict this instance to its own database only
list_db = False
dbfilter = ^{{ db_name }}$

http_interface = 0.0.0.0
proxy_mode = True
gevent_port = 8072

workers = {{ [cpu_limit | default(1) | int, 2] | max }}
max_cron_threads = 1
limit_memory_hard = {{ (mem_limit_mb | default(1024) | int * 1048576) | int }}
limit_memory_soft = {{ (mem_limit_mb | default(1024) | int * 838860) | int }}
limit_time_cpu = 600
limit_time_real = 1200

log_level = warn
