[options]
; Auto-generated by DafeApp — do not edit by hand.
; Instance: {{ client_name }}

addons_path = /mnt/extra-addons,/usr/lib/python3/dist-packages/odoo/addons
data_dir = /var/lib/odoo

db_host = postgres
db_port = 5432
db_user = odoo
db_password = {{ postgres_password }}
db_name = {{ db_name }}

; Restrict this instance to its own database only
list_db = False
db_filter = ^{{ db_name }}$

proxy_mode = True
gevent_port = 8072

workers = 2
max_cron_threads = 1
limit_memory_hard = 2684354560
limit_memory_soft = 2147483648
limit_time_cpu = 600
limit_time_real = 1200

log_level = warn
