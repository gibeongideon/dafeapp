# Copy this file to .env and fill in your values
# cp .env.example .env

# Django
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,dafeapp.com,www.dafeapp.com
CSRF_TRUSTED_ORIGINS=https://dafeapp.com,https://www.dafeapp.com
SITE_URL=https://dafeapp.com
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
# These default to True when DEBUG=False — only set False for local dev
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
# SECURE_SSL_REDIRECT=False

# Email (SMTP — required for password resets and notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@dafeapp.com

# PostgreSQL  (django-environ DATABASE_URL format)
# Docker: use service name 'db'. Local dev: use 'localhost'.
DATABASE_URL=postgres://dafeapp:dafeapp@db:5432/dafeapp

# Redis
# Docker: use service name 'redis'. Local dev: use 'localhost'.
REDIS_URL=redis://redis:6379/0

# Field-level encryption for cloud credentials — REQUIRED, app will not start without this
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ---------------------------------------------------------------------------
# Terraform / Ansible (Odoo version-specific server + instance flow)
# ---------------------------------------------------------------------------
# Directory containing main.tf for server provisioning.
# Leave unset to use provider-native API provisioning (recommended for Docker deployments).
# Local dev only: set to absolute path of infra/terraform/odoo_server if you want Terraform.
# TERRAFORM_SERVER_MODULE_DIR=

# ---------------------------------------------------------------------------
# Odoo server installation method: BARE (direct Ubuntu, no Docker)
# Docker support is planned for a future release.
# ---------------------------------------------------------------------------
# Install scripts are version-specific (one per Odoo release):
#   installscript/17.0/InstallScript/odoo_install.sh  ← Odoo 17
#   installscript/18.0/InstallScript/odoo_install.sh  ← Odoo 18
#   installscript/19.0/InstallScript/odoo_install.sh  ← Odoo 19
#
# setup_odoo_server_bare.yml automatically picks the right script based on
# the odoo_version passed by DafeApp (17, 18, or 19).
#
# Two server playbooks are available — set ANSIBLE_ODOO_SERVER_PLAYBOOK to
# whichever method you want DafeApp to use when provisioning new Odoo servers.
#
#   BARE  (recommended): uploads the version-specific odoo_install.sh.
#     ANSIBLE_ODOO_SERVER_PLAYBOOK=.../infra/ansible/setup_odoo_server_bare.yml
#
#   MANUAL-CLONE (original): installs deps and clones Odoo from GitHub manually.
#     ANSIBLE_ODOO_SERVER_PLAYBOOK=.../infra/ansible/setup_odoo_server.yml

# Leave these unset — the app resolves playbook paths automatically from infra/ansible/.
# Only override if you have custom playbooks in a different location.
# ANSIBLE_ODOO_SERVER_PLAYBOOK=
# ANSIBLE_ODOO_INSTANCE_DIRECT_PLAYBOOK=
# ANSIBLE_ODOO_INSTANCE_DELETE_PLAYBOOK=
# ANSIBLE_ODOO_INSTANCE_PLAYBOOK=

# Admin e-mail passed to certbot/Let's Encrypt when a domain is set on the server.
# Leave as the placeholder to disable SSL (certbot skips placeholder addresses).
ODOO_ADMIN_EMAIL=odoo@example.com

# Platform domain automation (used for automatic instance subdomains like app1.dafeapp.com)
PLATFORM_BASE_DOMAIN=dafeapp.com
PLATFORM_DNS_PROVIDER=
PLATFORM_DNS_API_TOKEN=
PLATFORM_DNS_ZONE_ID=
PLATFORM_DNS_PROXIED=False

# Optional DNS hook script called with: <fqdn> <ip>
# DNS_CREATE_HOOK_CMD=

# ---------------------------------------------------------------------------
# DafeApp SSH keypair — used for PYOS server connections (DAFEAPP_KEY auth)
# and passed to Ansible as --private-key.
#
# Setup (one time):
#   ssh-keygen -t ed25519 -f ~/.ssh/dafeapp_id_ed25519 -N ""
#   # Then add the public key to each PYOS server:
#   ssh-copy-id -i ~/.ssh/dafeapp_id_ed25519.pub user@your-server
#
# Set ANSIBLE_SSH_USER to the remote user Ansible/DafeApp will connect as.
# ---------------------------------------------------------------------------
# ANSIBLE_SSH_KEY_PATH=  # Only needed for PYOS (Bring Your Own Server) connections
ANSIBLE_SSH_USER=root

# ---------------------------------------------------------------------------
# Docker deployment mode (Traefik + containers — alternative to bare-metal)
# Set deployment_mode=DOCKER on an OdooServer to use these playbooks instead.
# ---------------------------------------------------------------------------
# Leave these unset — defaults resolve to infra/ansible/ inside the container automatically.
# ANSIBLE_DOCKER_HOST_PLAYBOOK=
# ANSIBLE_DOCKER_INSTANCE_PLAYBOOK=
# ANSIBLE_DOCKER_INSTANCE_DELETE_PLAYBOOK=

# Default PostgreSQL password for the shared Docker PostgreSQL container.
# Used when OdooServer.docker_postgres_password is blank.
DOCKER_POSTGRES_PASSWORD=odoo_secret

# ---------------------------------------------------------------------------
# Optional SSH checks (legacy provisioning path)
# ---------------------------------------------------------------------------
# TERRAFORM_SSH_USER=ubuntu
# TERRAFORM_SSH_KEY_PATH=
# TERRAFORM_SSH_TIMEOUT=15

# ---------------------------------------------------------------------------
# Provider credential envs used by starter Terraform / DNS scripts
# ---------------------------------------------------------------------------
# DigitalOcean Terraform + DNS (if DNS_PROVIDER=digitalocean)
DIGITALOCEAN_TOKEN=
# DigitalOcean OAuth app for "Connect with DigitalOcean"
# Callback URL example:
# https://dafeapp.com/cloud/accounts/digitalocean/oauth/callback/
DIGITALOCEAN_CLIENT_ID=
DIGITALOCEAN_CLIENT_SECRET=
DNS_PROVIDER=
DNS_ROOT_DOMAIN=

# AWS Terraform + DNS (if DNS_PROVIDER=route53)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
AWS_ROUTE53_ZONE_ID=

